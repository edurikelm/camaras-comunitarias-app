# Puerto del servicio realtime
REALTIME_PORT=3001

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated

# Issuer del JWT emitido por Supabase GoTrue. Por convencion Supabase firma
# con `iss = ${SUPABASE_URL}/auth/v1` (con el sufijo /auth/v1). Si este campo
# queda vacio, server.ts usa ese default automaticamente. Solo definirlo si
# Supabase cambia el formato o usas un proxy de auth custom.
# SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1

# Database (mismo DATABASE_URL que Next.js root)
DATABASE_URL=postgresql://user:pass@host:5432/db

# Secret compartido para /internal/emit
REALTIME_INTERNAL_SECRET=cambia-este-secret-en-produccion

# URL del servicio realtime para emitir desde Next.js (usada por el helper emitRealtimeEvent)
# El helper usa http://localhost:3001/internal/emit como default si no está definida
REALTIME_INTERNAL_URL=http://localhost:3001/internal/emit

# CORS para el handshake de Socket.IO
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
