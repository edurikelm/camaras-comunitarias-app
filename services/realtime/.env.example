# Puerto del servicio realtime
REALTIME_PORT=3001

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated

# Database (mismo DATABASE_URL que Next.js root)
DATABASE_URL=postgresql://user:pass@host:5432/db

# Secret compartido para /internal/emit
REALTIME_INTERNAL_SECRET=cambia-este-secret-en-produccion

# URL del servicio realtime para emitir desde Next.js (usada por el helper emitRealtimeEvent)
# El helper usa http://localhost:3001/internal/emit como default si no está definida
REALTIME_INTERNAL_URL=http://localhost:3001/internal/emit

# CORS para el handshake de Socket.IO
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
