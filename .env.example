# Runtime connection, usually Supabase pooler/PgBouncer.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[POOLER_HOST]:6543/postgres?pgbouncer=true"

# Direct database connection for Prisma CLI migrations.
DIRECT_URL="postgresql://postgres:[PASSWORD]@[DIRECT_HOST]:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
MEDIA_SERVER_WEBRTC_BASE_URL="https://media.example.com"

# Server-side pepper used to hash invitation codes before storing them.
INVITATION_PEPPER="replace-with-a-long-random-secret"

# URL publica del servicio Socket.IO realtime (browser client).
# El server usa REALTIME_INTERNAL_URL (otro env var) para emitir via HTTP POST.
NEXT_PUBLIC_REALTIME_URL=http://localhost:3001
